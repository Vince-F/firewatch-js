{
  "name": "firewatch-js",
  "version": "1.0.0",
  "description": "A library to send application log to any backend",
  "keywords": [
    "logs",
    "errors",
    "browser"
  ],
  "license": "MIT",
  "author": "Vincent Francolin",
  "type": "module",
  "main": "./dist/firewatch-js.js",
  "scripts": {
    "checkAndBuildAll": "npm run lint:check && npm run test && npm run build && npm run types && npm run doc",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "doc": "typedoc",
    "test": "vitest run",
    "types": "tsc --emitDeclarationOnly",
    "lint:fix": "prettier --write . && eslint --fix .",
    "lint:check": "prettier --check . && eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
